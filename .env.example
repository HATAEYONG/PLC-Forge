# ── Django ──────────────────────────────────────────────
# 운영에서는 반드시 무작위 시크릿으로 교체
DJANGO_SECRET_KEY=change-me
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=plcforge
POSTGRES_USER=plcforge
POSTGRES_PASSWORD=plcforge
# docker compose 사용 시 backend 컨테이너에서는 host가 "db"
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ── Frontend ────────────────────────────────────────────
# 비워두면 Vite dev proxy(/api → backend)를 사용
VITE_API_BASE_URL=
